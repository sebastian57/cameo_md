# MLCG simulation: 1pro_alltemp all-atom model, ML-only force field.
#
# Short smoke-test input based on inp_lammps_mlcg_1pro_ml_only_langevin.in.
# Uses an all-atom LAMMPS data file generated by lmp_input_gen_aa.py and the
# all-atom symbolic model exported to cameo_md/models.
#
# NVE only: no Langevin thermostat/noise.
# comm_cutoff = 12.0, matching the AA data-file box clearance basis.

variable data_file         string "/p/project1/cameo/schmidt36/cameo_md/structures/config_4z_aa_frame0.data"
variable model_file        string "/p/project1/cameo/schmidt36/cameo_md/models/1pro_alltemp_aa_reexport_symbolic.mlir"
variable dump_dir          string "/p/project1/cameo/schmidt36/cameo_md/outputs/exp_1pro_tica/mlcg_aa_structure_ml_only_nve_short"

variable temp              equal 320.0
variable dt_fs             equal 0.1
variable eq_steps          equal 50000
variable sample_steps      equal 200000
variable sample_stride     equal 50

# chemtrain_deploy settings
variable xla_mem_fraction  equal 0.90
variable comm_cutoff       equal 12.0
variable ghost_mult        equal 1.2
variable edge_mult         equal 1.1

units           real
atom_style      atomic
dimension       3
boundary        p p p

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes once no

read_data       ${data_file}

# Per-element masses are provided by the all-atom data file.

comm_modify     cutoff ${comm_cutoff}
pair_style      chemtrain_deploy cuda12 ${xla_mem_fraction}
pair_coeff      * * ${model_file} ${ghost_mult} ${edge_mult}

timestep        ${dt_fs}

thermo          1000
thermo_style    custom step temp press pe ke etotal

min_style       cg
minimize        1.0e-4 1.0e-6 200 2000

velocity        all create ${temp} 42 mom yes rot yes dist gaussian
fix             int  all nve

run             ${eq_steps}
write_restart   ${dump_dir}/restart.eq

reset_timestep  0
dump            dprod all custom ${sample_stride} ${dump_dir}/aa_tica.dump id type xu yu zu fx fy fz
dump_modify     dprod sort id format line "%d %d %.8f %.8f %.8f %.8f %.8f %.8f"

run             ${sample_steps}
write_restart   ${dump_dir}/restart.prod
