# Fixed-CA CHARMM22+CMAP run for Option 3 style force statistics.
#
# Protocol:
# - free minimization
# - CA frozen during dynamics
# - dump CA reference structures and protein force trajectory

variable data_file      string "/p/project1/cameo/schmidt36/cameo_md/runs/forcevar_320K/4zohB01/data.protein"
variable cmap_file      string "/p/project1/cameo/schmidt36/cameo_md/runs/forcevar_320K/4zohB01/charmm22.cmap"
variable dump_dir       string "/p/project1/cameo/schmidt36/cameo_md/outputs/compare_clean/charmm22_fixedca"

variable temp           equal 320.0
variable dt_fs          equal 1.0
variable eq_steps       equal 0
variable sample_steps   equal 10000
variable sample_stride  equal 10

units           real
atom_style      full
boundary        p p p

bond_style      harmonic
angle_style     charmm
dihedral_style  charmm
improper_style  harmonic

pair_style      lj/charmm/coul/long 8.0 12.0
pair_modify     mix arithmetic
kspace_style    pppm 1.0e-6
special_bonds   charmm

fix             cmap all cmap ${cmap_file}
fix_modify      cmap energy yes
read_data       ${data_file} fix cmap crossterm CMAP

# The orchestrator injects include ca_group.lmp after read_data
# and rewrites this protein group bound per run.
group           protein id 1:868

timestep        ${dt_fs}

# Initial CA snapshot for ML t0 seed generation (before any dynamics)
reset_timestep  0
dump            dt0 ca custom 1 ${dump_dir}/ca_t0.dump id type xu yu zu
dump_modify     dt0 sort id format line "%d %d %.8f %.8f %.8f"
run             0
undump          dt0

# Freeze CA first so minimization only relaxes mobile atoms
fix             freeze_ca ca setforce 0.0 0.0 0.0

# Minimization with frozen CA (non-CA atoms relax to frozen CA positions)
min_style       cg
minimize        1.0e-4 1.0e-6 500 5000
reset_timestep  0

# Thermal dynamics with frozen CA
velocity        all create ${temp} 42 mom yes rot yes dist gaussian
velocity        ca set 0.0 0.0 0.0

fix             int  mobile nve
fix             bath mobile langevin ${temp} ${temp} 100.0 24680 zero yes
fix             sh   all shake 1.0e-6 500 0 m 1.0 a 110

thermo          5000
thermo_style    custom step temp press pe ke etotal

# Optional short equilibration under constraints
run             ${eq_steps}
write_restart   ${dump_dir}/restart.eq_fixed

# CA snapshot after constrained equilibration
reset_timestep  0
dump            deq ca custom 1 ${dump_dir}/ca_eq_final.dump id type xu yu zu
dump_modify     deq sort id format line "%d %d %.8f %.8f %.8f"
run             0
undump          deq

# Production force sampling for Option 3
reset_timestep  0
dump            dca   ca      custom ${sample_stride} ${dump_dir}/ca_forces.dump      id type xu yu zu fx fy fz
dump_modify     dca   sort id format line "%d %d %.8f %.8f %.8f %.10f %.10f %.10f"
dump            dprot protein custom ${sample_stride} ${dump_dir}/protein_forces.dump id type xu yu zu fx fy fz
dump_modify     dprot sort id format line "%d %d %.8f %.8f %.8f %.10f %.10f %.10f"

run             ${sample_steps}
write_restart   ${dump_dir}/restart.prod_fixed
